# ============================================================
# Modelo do .env de PRODUÇÃO (usado pelo docker-compose.prod.yml)
# Copie para /opt/todolist02/.env NO SERVIDOR e preencha.
# O .env real nunca vai para o git (está no .gitignore).
# ============================================================

# Seu usuário/organização no GitHub, em minúsculas (dono das imagens no GHCR)
GHCR_OWNER=seu-usuario-github

# Qual versão das imagens rodar: latest, v1.0.0 ou um SHA curto (rollback)
IMAGE_TAG=latest

# Banco de dados
DB_USER=todouser
DB_PASSWORD=troque-por-uma-senha-forte
DB_NAME=todolist02

# Segredo do JWT — gere um valor longo e aleatório, ex.: openssl rand -hex 32
JWT_SECRET=troque-por-um-segredo-longo-aleatorio
